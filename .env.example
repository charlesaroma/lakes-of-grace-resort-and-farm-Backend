NODE_ENV=development
PORT=5001
MONGO_URI=mongodb://localhost:27017/lakes-of-grace
JWT_ACCESS_SECRET=your_access_secret_at_least_20_chars_long
JWT_REFRESH_SECRET=your_refresh_secret_at_least_20_chars_long
FRONTEND_URL=http://localhost:5173

# ImageKit — get your keys from https://imagekit.io/dashboard/developer
IMAGEKIT_PUBLIC_KEY=your_public_key_here
IMAGEKIT_PRIVATE_KEY=your_private_key_here
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id
